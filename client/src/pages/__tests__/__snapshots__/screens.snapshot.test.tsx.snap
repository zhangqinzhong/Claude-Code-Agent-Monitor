              class="w-full bg-surface-2 border border-border rounded pl-7 pr-2 py-1.5 text-xs text-gray-200 placeholder-gray-500 focus:outline-none focus:border-accent"
              placeholder="Search summary, tool, payload..."
              type="text"
              value=""
