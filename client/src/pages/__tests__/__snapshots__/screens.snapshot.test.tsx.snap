              type="button"
            >
              <span>
                Tool
              </span>
            </button>
          </div>
        </div>
      </div>
    </div>
    <div
      class="flex items-center gap-2 mb-3 px-1"
    >
      <div
        aria-label="view mode"
        class="inline-flex rounded-md border border-border overflow-hidden"
        role="group"
      >
        <button
          aria-pressed="true"
          class="text-[11px] px-3 py-1 cursor-pointer bg-accent/20 text-accent"
          type="button"
        >
          Group by tool call
        </button>
        <button
