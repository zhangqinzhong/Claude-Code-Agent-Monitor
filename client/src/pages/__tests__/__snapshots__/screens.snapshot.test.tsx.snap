              class="inline-flex items-center gap-1.5 text-xs font-medium text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-2.5 py-1 rounded-full"
            >
              <svg
                class="lucide lucide-circle-check-big w-3.5 h-3.5"
                fill="none"
                height="24"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                viewBox="0 0 24 24"
                width="24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M21.801 10A10 10 0 1 1 17 3.335"
                />
                <path
                  d="m9 11 3 3L22 4"
                />
              </svg>
               
              All hooks installed
            </span>
          </div>
          <button
            class="btn-ghost text-xs disabled:opacity-50"
          >
            <svg
              class="lucide lucide-rotate-ccw w-3.5 h-3.5"
              fill="none"
              height="24"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              viewBox="0 0 24 24"
              width="24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"
              />
              <path
                d="M3 3v5h5"
              />
            </svg>
            Reinstall Hooks
          </button>
        </div>
        <div
          class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-2"
        />
        <p
          class="text-[11px] text-gray-600 font-mono truncate"
        >
          /tmp/settings.json
        </p>
      </div>
    </section>
    <section
      class="scroll-mt-24"
      id="claude-home"
    >
      <h3
        class="text-sm font-medium text-gray-300 flex items-center gap-2 mb-1"
      >
        <svg
          class="lucide lucide-folder-open w-4 h-4 text-gray-500"
          fill="none"
          height="24"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          viewBox="0 0 24 24"
          width="24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="m6 14 1.5-2.9A2 2 0 0 1 9.24 10H20a2 2 0 0 1 1.94 2.5l-1.54 6a2 2 0 0 1-1.95 1.5H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h3.9a2 2 0 0 1 1.69.9l.81 1.2a2 2 0 0 0 1.67.9H18a2 2 0 0 1 2 2v2"
          />
        </svg>
        CLAUDE_HOME
      </h3>
      <p
        class="text-xs text-gray-500 mb-4"
      >
        Root directory for Claude Code session data. Changing this updates the scan path for transcripts and imports immediately.
      </p>
      <div
        class="card p-5 space-y-4"
      >
        <div
          class="flex items-center gap-3"
        >
          <input
            class="flex-1 bg-surface-4 border border-surface-3 rounded-lg px-3 py-2 text-sm text-gray-200 font-mono focus:outline-none focus:border-violet-500/50"
            placeholder="/path/to/claude-home"
            type="text"
            value="/home/test/.claude"
          />
          <button
            class="btn-primary px-4 py-2 text-sm disabled:opacity-50 disabled:cursor-not-allowed"
            disabled=""
          >
            Save
          </button>
        </div>
        <p
          class="text-xs text-gray-500"
        >
          Current:
           
          <code
            class="text-gray-400"
          >
            /home/test/.claude
          </code>
        </p>
      </div>
    </section>
    <section
      class="scroll-mt-24"
      id="import"
    >
      <section>
        <h3
          class="text-sm font-medium text-gray-300 flex items-center gap-2 mb-1"
        >
          <svg
            class="lucide lucide-history w-4 h-4 text-gray-500"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"
            />
            <path
              d="M3 3v5h5"
            />
            <path
              d="M12 7v5l4 2"
            />
          </svg>
          Import History
        </h3>
        <p
          class="text-xs text-gray-500 mb-4"
        >
          Bring existing Claude Code sessions into the dashboard. Token counts, per-model cost, compactions, subagents, tool uses, and turn durations are reconstructed from the original JSONL transcripts - identical to how live sessions are captured.
        </p>
        <div
          class="card p-5 space-y-5"
        >
          <div
            class="border border-border rounded-lg overflow-hidden"
          >
            <button
              class="w-full flex items-center justify-between px-4 py-3 bg-surface-2 hover:bg-surface-3 transition-colors"
            >
              <span
                class="flex items-center gap-2 text-xs font-semibold text-gray-300 uppercase tracking-wider"
              >
                <svg
                  class="lucide lucide-list-checks w-3.5 h-3.5 text-blue-400"
                  fill="none"
                  height="24"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                  width="24"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="m3 17 2 2 4-4"
                  />
                  <path
                    d="m3 7 2 2 4-4"
                  />
                  <path
                    d="M13 6h8"
                  />
                  <path
                    d="M13 12h8"
                  />
                  <path
                    d="M13 18h8"
                  />
                </svg>
                How to gather your history
              </span>
              <span
                class="text-[11px] text-gray-500"
              >
                ▾
              </span>
            </button>
            <div
              class="px-4 py-4 space-y-4 text-sm text-gray-300 bg-surface-1"
            >
              <div
                class="flex flex-wrap items-center gap-2 text-xs bg-surface-2 border border-border rounded-md px-3 py-2"
              >
                <svg
                  class="lucide lucide-hard-drive w-3.5 h-3.5 text-gray-500 flex-shrink-0"
                  fill="none"
                  height="24"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                  width="24"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <line
                    x1="22"
                    x2="2"
                    y1="12"
                    y2="12"
                  />
                  <path
                    d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"
                  />
                  <line
                    x1="6"
                    x2="6.01"
                    y1="16"
                    y2="16"
                  />
                  <line
                    x1="10"
                    x2="10.01"
                    y1="16"
                    y2="16"
                  />
                </svg>
                <span
                  class="text-gray-400"
                >
                  Default location on this machine
                  :
                </span>
                <code
                  class="font-mono text-gray-200 truncate"
                >
                  ~/.claude/projects
                </code>
                <span
                  class="inline-flex items-center gap-1 text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-2 py-0.5 rounded-full"
                >
                  <svg
                    class="lucide lucide-circle-check w-3 h-3"
                    fill="none"
                    height="24"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                    width="24"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <circle
                      cx="12"
                      cy="12"
                      r="10"
                    />
                    <path
                      d="m9 12 2 2 4-4"
                    />
                  </svg>
                  Folder found
                  <span
                    class="text-gray-500 ml-1"
                  >
                    · 
                    0
                     
                    projects
                    ,
                     
                    0
                     
                    JSONL files
                  </span>
                </span>
              </div>
              <div
                class="space-y-3"
              >
                <div>
                  <p
                    class="text-sm font-medium text-gray-200"
                  >
                    1. Locate your Claude Code history
                  </p>
                  <p
                    class="text-xs text-gray-400 mt-1 whitespace-pre-line"
                  >
                    Every Claude Code session is stored as a JSONL transcript under the projects folder. Each subfolder is named after the working directory where the session started (slashes replaced with dashes).
                  </p>
                </div>
                <div>
                  <p
                    class="text-sm font-medium text-gray-200"
                  >
                    2. Bundle it for transfer (optional)
                  </p>
                  <p
                    class="text-xs text-gray-400 mt-1 whitespace-pre-line"
                  >
                    To move history from another machine, archive the whole folder first, then copy it over (AirDrop, scp, USB, cloud storage):
                  </p>
                  <div
                    class="mt-2 flex items-center gap-2 bg-surface-2 border border-border rounded-md px-3 py-2"
                  >
                    <svg
                      class="lucide lucide-terminal w-3.5 h-3.5 text-gray-500 flex-shrink-0"
                      fill="none"
                      height="24"
                      stroke="currentColor"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      viewBox="0 0 24 24"
                      width="24"
                      xmlns="http://www.w3.org/2000/svg"
                    >
                      <polyline
                        points="4 17 10 11 4 5"
                      />
                      <line
                        x1="12"
                        x2="20"
                        y1="19"
                        y2="19"
                      />
                    </svg>
                    <code
                      class="flex-1 text-xs font-mono text-gray-200 truncate"
                    >
                      tar
                    </code>
                    <button
                      class="text-xs text-gray-400 hover:text-gray-200 flex items-center gap-1 flex-shrink-0"
                    >
                      <svg
                        class="lucide lucide-copy w-3 h-3"
                        fill="none"
                        height="24"
                        stroke="currentColor"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        viewBox="0 0 24 24"
                        width="24"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <rect
                          height="14"
                          rx="2"
                          ry="2"
                          width="14"
                          x="8"
                          y="8"
                        />
                        <path
                          d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"
                        />
                      </svg>
                       
                      Copy
                    </button>
                  </div>
                </div>
                <div>
                  <p
                    class="text-sm font-medium text-gray-200"
                  >
                    3. Pick an import mode below
                  </p>
                  <p
                    class="text-xs text-gray-400 mt-1 whitespace-pre-line"
                  >
                    Rescan the default location, point at any folder you've extracted history into, or upload files/archives directly.
                  </p>
                </div>
                <div>
                  <p
                    class="text-sm font-medium text-gray-200"
                  >
                    4. Verify tokens and cost
                  </p>
                  <p
                    class="text-xs text-gray-400 mt-1 whitespace-pre-line"
                  >
                    After import, open Analytics → Cost to confirm the breakdown. Re-importing the same session is always safe.
                  </p>
                </div>
              </div>
              <div
                class="text-[11px] text-gray-500 flex items-start gap-2 pt-2 border-t border-border"
              >
                <svg
                  class="lucide lucide-info w-3 h-3 mt-0.5 flex-shrink-0"
                  fill="none"
                  height="24"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                  width="24"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <circle
                    cx="12"
                    cy="12"
                    r="10"
                  />
                  <path
                    d="M12 16v-4"
                  />
                  <path
                    d="M12 8h.01"
                  />
                </svg>
                <span>
                  Re-running is safe. Sessions are deduplicated by session ID, and compaction baselines ensure token totals never double-count.
                </span>
              </div>
            </div>
          </div>
          <div
            class="grid grid-cols-1 sm:grid-cols-3 gap-2"
          >
            <button
              class="text-left p-3 rounded-lg border transition-colors border-blue-500/40 bg-blue-500/10"
            >
              <div
                class="flex items-center gap-1.5 text-xs font-medium mb-1 text-blue-300"
              >
                <svg
                  class="lucide lucide-refresh-cw w-3.5 h-3.5"
                  fill="none"
                  height="24"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                  width="24"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"
                  />
                  <path
                    d="M21 3v5h-5"
                  />
                  <path
                    d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"
                  />
                  <path
                    d="M8 16H3v5"
                  />
                </svg>
                Rescan default folder
              </div>
              <p
                class="text-[11px] text-gray-500 leading-snug"
              >
                Re-read ~/.claude/projects and import anything new.
              </p>
            </button>
            <button
              class="text-left p-3 rounded-lg border transition-colors border-border bg-surface-2 hover:bg-surface-3"
            >
              <div
                class="flex items-center gap-1.5 text-xs font-medium mb-1 text-gray-300"
              >
                <svg
                  class="lucide lucide-folder-input w-3.5 h-3.5"
                  fill="none"
                  height="24"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                  width="24"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M2 9V5a2 2 0 0 1 2-2h3.9a2 2 0 0 1 1.69.9l.81 1.2a2 2 0 0 0 1.67.9H20a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-1"
                  />
                  <path
                    d="M2 13h10"
                  />
                  <path
                    d="m9 16 3-3-3-3"
                  />
                </svg>
                Scan a folder
              </div>
              <p
                class="text-[11px] text-gray-500 leading-snug"
              >
                Scan any directory on this machine for JSONL transcripts (walks subfolders).
              </p>
            </button>
            <button
              class="text-left p-3 rounded-lg border transition-colors border-border bg-surface-2 hover:bg-surface-3"
            >
              <div
                class="flex items-center gap-1.5 text-xs font-medium mb-1 text-gray-300"
              >
                <svg
                  class="lucide lucide-cloud-upload w-3.5 h-3.5"
                  fill="none"
                  height="24"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                  width="24"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M12 13v8"
                  />
                  <path
                    d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242"
                  />
                  <path
                    d="m8 17 4-4 4 4"
                  />
                </svg>
                Upload files
              </div>
              <p
                class="text-[11px] text-gray-500 leading-snug"
              >
                Drop JSONL files or an archive (.zip / .tar.gz) directly into the browser.
              </p>
            </button>
          </div>
          <div
            class="bg-surface-2 border border-border rounded-lg p-4"
          >
            <div
              class="flex flex-wrap items-center justify-between gap-3"
            >
              <div
                class="flex items-center gap-3 min-w-0"
              >
                <svg
                  class="lucide lucide-folder-open w-4 h-4 text-gray-500 flex-shrink-0"
                  fill="none"
                  height="24"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                  width="24"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="m6 14 1.5-2.9A2 2 0 0 1 9.24 10H20a2 2 0 0 1 1.94 2.5l-1.54 6a2 2 0 0 1-1.95 1.5H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h3.9a2 2 0 0 1 1.69.9l.81 1.2a2 2 0 0 0 1.67.9H18a2 2 0 0 1 2 2v2"
                  />
                </svg>
                <code
                  class="font-mono text-xs text-gray-300 truncate"
                >
                  ~/.claude/projects
                </code>
              </div>
              <button
                class="btn-primary text-xs disabled:opacity-50"
              >
                <svg
                  class="lucide lucide-refresh-cw w-3.5 h-3.5"
                  fill="none"
                  height="24"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                  width="24"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"
                  />
                  <path
                    d="M21 3v5h-5"
                  />
                  <path
                    d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"
                  />
                  <path
                    d="M8 16H3v5"
                  />
                </svg>
                Rescan Now
              </button>
            </div>
          </div>
        </div>
      </section>
    </section>
    <section
      class="scroll-mt-24"
      id="tabby"
    >
      <h3
        class="text-sm font-medium text-gray-300 flex items-center gap-2 mb-1"
      >
        <span
          aria-hidden="true"
          class="text-base leading-none"
        >
          🐾
        </span>
        Tabby companion
      </h3>
      <p
        class="text-xs text-gray-500 mb-4"
      >
        A floating cat that reacts to your live sessions.
      </p>
      <div
        class="card p-5"
      >
        <div
          class="flex items-center gap-3"
        >
          <div
            class="w-10 h-10 rounded-xl flex items-center justify-center transition-colors bg-blue-500/10 border border-blue-500/20"
          >
            <span
              aria-hidden="true"
              class="text-lg leading-none"
            >
              🐾
            </span>
          </div>
          <label
            class="flex items-center justify-between gap-3 cursor-pointer group"
          >
            <div
              class="min-w-0"
            >
              <p
                class="text-sm text-gray-300 group-hover:text-gray-200 transition-colors"
              >
                Show Tabby
              </p>
              <p
                class="text-xs text-gray-500 mt-0.5"
              >
                Display the corner companion across the dashboard (⌘B to open)
              </p>
            </div>
            <button
              aria-checked="true"
              class="relative inline-flex h-5 w-9 flex-shrink-0 rounded-full border-2 border-transparent transition-colors duration-200 bg-blue-500"
              role="switch"
              type="button"
            >
              <span
                class="pointer-events-none inline-block h-4 w-4 rounded-full bg-white shadow transform transition-transform duration-200 translate-x-4"
              />
            </button>
          </label>
        </div>
      </div>
    </section>
    <section
      class="scroll-mt-24"
      id="notifications"
    >
      <h3
        class="text-sm font-medium text-gray-300 flex items-center gap-2 mb-1"
      >
        <svg
          class="lucide lucide-bell w-4 h-4 text-gray-500"
          fill="none"
          height="24"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          viewBox="0 0 24 24"
          width="24"
