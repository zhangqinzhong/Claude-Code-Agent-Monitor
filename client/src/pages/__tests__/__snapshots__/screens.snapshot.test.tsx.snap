          class="text-[11px] px-3 py-1 border-l border-border cursor-pointer bg-surface-2 text-gray-400 hover:text-gray-200"
          type="button"
        >
          Flat list
        </button>
      </div>
    </div>
    <div
      class="flex flex-col items-center justify-center py-20 text-center"
