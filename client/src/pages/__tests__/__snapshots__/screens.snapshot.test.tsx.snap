            <path
              d="M8 16H3v5"
            />
          </svg>
          Refresh
        </button>
        <button
          class="btn-ghost"
        >
          <svg
            class="lucide lucide-download w-4 h-4"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="24"
