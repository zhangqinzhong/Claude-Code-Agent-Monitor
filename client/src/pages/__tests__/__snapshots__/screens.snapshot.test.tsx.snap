exports[`screen snapshots > Activity feed 1`] = `
<div>
  <div
    class="animate-fade-in"
  >
    <div
      class="flex flex-wrap items-center justify-between gap-3 mb-6"
    >
      <div
        class="flex items-center gap-3"
      >
        <div
          class="w-9 h-9 rounded-xl bg-accent/15 flex items-center justify-center"
        >
          <svg
            class="lucide lucide-activity w-4.5 h-4.5 text-accent"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.49 12H2"
            />
          </svg>
        </div>
        <div>
          <div
            class="flex items-center gap-2"
          >
            <h1
              class="text-lg font-semibold text-gray-100"
            >
              Activity Feed
            </h1>
            <span
              class="flex items-center gap-1.5 text-[11px] text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-2 py-0.5 rounded-full"
            >
              <span
                class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse-dot"
              />
              Live
            </span>
          </div>
          <p
            class="text-xs text-gray-500"
          >
            Real-time stream of all agent events
          </p>
        </div>
      </div>
      <div
        class="flex items-center gap-2 flex-shrink-0"
      >
        <button
          class="btn-ghost"
        >
          <svg
            class="lucide lucide-pause w-4 h-4"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <rect
              height="16"
              rx="1"
              width="4"
              x="14"
              y="4"
            />
            <rect
              height="16"
              rx="1"
              width="4"
              x="6"
              y="4"
            />
          </svg>
           
          Pause
        </button>
        <button
          class="btn-ghost"
        >
          <svg
            class="lucide lucide-refresh-cw w-4 h-4"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"
            />
            <path
              d="M21 3v5h-5"
            />
            <path
              d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"
            />
            <path
              d="M8 16H3v5"
            />
          </svg>
        </button>
      </div>
    </div>
    <div
      class="mb-3"
    >
      <details
        class="card bg-surface-2/40 border border-border rounded overflow-hidden"
      >
        <summary
          class="cursor-pointer select-none px-3 py-2 flex items-center text-[11px] text-gray-400 hover:text-gray-200 hover:bg-surface-2/80"
        >
          <svg
            class="lucide lucide-info w-3.5 h-3.5 mr-2"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <circle
              cx="12"
              cy="12"
              r="10"
            />
            <path
              d="M12 16v-4"
            />
            <path
              d="M12 8h.01"
            />
          </svg>
          <span
            class="font-semibold uppercase tracking-wide mr-1.5"
          >
            About events, filters, and grouping
          </span>
          <span
            class="text-gray-500 font-normal"
          >
            - 
            Unlock deeper insights: badges, lifecycles, and filter mechanics explained.
          </span>
        </summary>
        <div
          class="divide-y divide-border"
        >
          <details
            class="group"
            open=""
          >
            <summary
              class="cursor-pointer select-none px-3 py-1.5 text-[11px] text-gray-300 hover:bg-surface-2/60 flex items-center gap-2"
            >
              <span
                class="text-gray-500 transition-transform group-open:rotate-90"
              >
                ▶
              </span>
              <span
                class="font-semibold uppercase tracking-wide text-gray-400"
              >
                Status badges
              </span>
            </summary>
            <div
              class="px-3 pb-3 pt-1"
            >
              <p
                class="text-[11px] text-gray-500 mb-2"
              >
                Status is derived from event_type. It's what you see on each row.
              </p>
              <dl
                class="grid grid-cols-[auto_1fr] gap-x-3 gap-y-1.5 text-[11px]"
              >
                <dt>
                  <span
                    class="badge bg-emerald-500/10 border-emerald-500/20 text-emerald-400"
                  >
                    <span
                      class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse-dot"
                    />
                    Working
                  </span>
                </dt>
                <dd
                  class="self-center"
                >
                  Agent started a tool call (PreToolUse). The tool is about to run.
                </dd>
                <dt>
                  <span
                    class="badge bg-yellow-500/10 border-yellow-500/20 text-yellow-400"
                  >
                    <span
                      class="w-1.5 h-1.5 rounded-full bg-yellow-400 animate-pulse-dot"
                    />
                    Waiting
                  </span>
                </dt>
                <dd
                  class="self-center"
                >
                  eventFilters.help.statusWaitingDesc
                </dd>
                <dt>
                  <span
                    class="badge bg-violet-500/10 border-violet-500/20 text-violet-400"
                  >
                    <span
                      class="w-1.5 h-1.5 rounded-full bg-violet-400 "
                    />
                    Completed
                  </span>
                </dt>
                <dd
                  class="self-center"
                >
                  Turn or lifecycle boundary (Stop, SubagentStop, Compaction).
                </dd>
                <dt>
                  <span
                    class="badge bg-red-500/10 border-red-500/20 text-red-400"
                  >
                    <span
                      class="w-1.5 h-1.5 rounded-full bg-red-400 "
                    />
                    Error
                  </span>
                </dt>
                <dd
                  class="self-center"
                >
                  An error was recorded (error, APIError).
                </dd>
              </dl>
            </div>
          </details>
          <details
            class="group"
            open=""
          >
            <summary
              class="cursor-pointer select-none px-3 py-1.5 text-[11px] text-gray-300 hover:bg-surface-2/60 flex items-center gap-2"
            >
              <span
                class="text-gray-500 transition-transform group-open:rotate-90"
              >
                ▶
              </span>
              <span
                class="font-semibold uppercase tracking-wide text-gray-400"
              >
                Event lifecycle
              </span>
            </summary>
            <div
              class="px-3 pb-3 pt-1"
            >
              <p
                class="text-[11px] text-gray-400 mb-2"
              >
                A typical tool call emits two events sharing the same tool_use_id:
              </p>
              <code
                class="block bg-black/40 border border-border rounded p-2 text-[11px] font-mono text-gray-300 whitespace-pre-wrap"
              >
                PreToolUse (Working) → PostToolUse (Connected) → ... → Stop (Completed)
              </code>
            </div>
          </details>
          <details
            class="group"
            open=""
          >
            <summary
              class="cursor-pointer select-none px-3 py-1.5 text-[11px] text-gray-300 hover:bg-surface-2/60 flex items-center gap-2"
            >
              <span
                class="text-gray-500 transition-transform group-open:rotate-90"
              >
                ▶
              </span>
              <span
                class="font-semibold uppercase tracking-wide text-gray-400"
              >
                How filters work
              </span>
            </summary>
            <div
              class="px-3 pb-3 pt-1"
            >
              <ul
                class="list-disc pl-5 space-y-1 text-[11px] text-gray-400"
              >
                <li>
                  Filters compose with AND across categories. Within one category, multi-select is OR.
                </li>
                <li>
                  Status is a shortcut that expands to event_type values (Working → PreToolUse, Completed → Stop/SubagentStop/Compaction, ...). Status + Event type compose as OR on event_type.
                </li>
                <li
                  class="text-amber-300/90"
                >
                  Grouping tip: a grouped row needs both Pre and Post events. If you filter by Status, pick Working + Connected together to keep pairs intact - otherwise a group will only show half of the call.
                </li>
                <li>
                  Text search matches summary, tool_name, and the raw payload (data column).
                </li>
                <li>
                  Date range applies to each event's created_at.
                </li>
              </ul>
            </div>
          </details>
          <details
            class="group"
            open=""
          >
            <summary
              class="cursor-pointer select-none px-3 py-1.5 text-[11px] text-gray-300 hover:bg-surface-2/60 flex items-center gap-2"
            >
              <span
                class="text-gray-500 transition-transform group-open:rotate-90"
              >
                ▶
              </span>
              <span
                class="font-semibold uppercase tracking-wide text-gray-400"
              >
                What each filter accepts
              </span>
            </summary>
            <div
              class="px-3 pb-3 pt-1"
            >
              <dl
                class="grid grid-cols-[auto_1fr] gap-x-3 gap-y-1.5 text-[11px]"
              >
                <dt
                  class="font-semibold text-gray-300 whitespace-nowrap"
                >
                  Status
                </dt>
                <dd
                  class="text-gray-400"
                >
                  Preset shortcut that expands to event_type values (Working → PreToolUse, Completed → Stop/SubagentStop/Compaction, ...).
                </dd>
                <dt
                  class="font-semibold text-gray-300 whitespace-nowrap"
                >
                  Event type
                </dt>
                <dd
                  class="text-gray-400"
                >
                  Raw event_type strings from the DB. Pulled from /api/events/facets.
                </dd>
                <dt
                  class="font-semibold text-gray-300 whitespace-nowrap"
                >
                  Tool
                </dt>
                <dd
                  class="text-gray-400"
                >
                  tool_name values currently in the DB (Bash, Edit, Read, Grep, mcp__... tools). Pulled from /api/events/facets.
                </dd>
                <dt
                  class="font-semibold text-gray-300 whitespace-nowrap"
                >
                  Agent
                </dt>
                <dd
                  class="text-gray-400"
                >
                  Full agent UUIDs (main + subagents). Select one or more to scope to specific agents.
                </dd>
                <dt
                  class="font-semibold text-gray-300 whitespace-nowrap"
                >
                  Session
                </dt>
                <dd
                  class="text-gray-400"
                >
                  Session UUIDs. Typically you'd navigate to /sessions/:id instead, but this lets you intersect multiple sessions.
                </dd>
                <dt
                  class="font-semibold text-gray-300 whitespace-nowrap"
                >
                  Search summary, tool, payload...
                </dt>
                <dd
                  class="text-gray-400"
                >
                  Substring match on summary, tool_name, and the raw JSON payload. Debounced 300ms.
                </dd>
                <dt
                  class="font-semibold text-gray-300 whitespace-nowrap"
                >
                  From / To
                </dt>
                <dd
                  class="text-gray-400"
                >
                  ISO datetime lower/upper bounds on the event's created_at.
                </dd>
              </dl>
            </div>
          </details>
        </div>
      </details>
    </div>
    <div
      class="mb-4"
    >
      <div
        class="card p-3 space-y-2"
      >
        <div
          class="flex flex-wrap items-center gap-2"
        >
          <svg
            class="lucide lucide-filter w-3.5 h-3.5 text-gray-500 flex-shrink-0"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <polygon
              points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"
            />
          </svg>
          <div
            class="relative flex-1 min-w-[180px]"
          >
            <svg
              class="lucide lucide-search absolute left-2 top-1/2 -translate-y-1/2 w-3 h-3 text-gray-500"
              fill="none"
              height="24"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              viewBox="0 0 24 24"
              width="24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <circle
                cx="11"
                cy="11"
                r="8"
              />
              <path
                d="m21 21-4.3-4.3"
              />
            </svg>
            <input
