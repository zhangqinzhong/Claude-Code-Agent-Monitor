            </button>
          </div>
          <span
            class="text-xs text-gray-600"
          >
            →
          </span>
          <div
            class="relative "
          >
            <button
              aria-label="To"
              class="flex items-center gap-2 bg-surface-2 border border-border rounded px-2 py-1.5 min-w-[150px] text-xs focus:outline-none focus:border-accent transition-colors w-full text-left"
              title="To"
              type="button"
            >
              <svg
                class="lucide lucide-calendar w-3.5 h-3.5 text-gray-400 shrink-0"
                fill="none"
                height="24"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                viewBox="0 0 24 24"
                width="24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M8 2v4"
                />
                <path
                  d="M16 2v4"
                />
                <rect
                  height="18"
                  rx="2"
                  width="18"
                  x="3"
                  y="4"
                />
                <path
                  d="M3 10h18"
                />
              </svg>
              <span
                class="flex-1 truncate text-gray-500"
              >
                To
              </span>
            </button>
          </div>
        </div>
        <div
          class="flex flex-wrap gap-2"
        >
          <div
            class="relative"
          >
            <button
              aria-expanded="false"
              aria-haspopup="listbox"
              class="text-[11px] px-2 py-1 rounded border cursor-pointer flex items-center gap-1.5 border-border bg-surface-2 text-gray-400 hover:text-gray-200"
              type="button"
            >
              <span>
                Status
              </span>
            </button>
          </div>
          <div
            class="relative"
          >
            <button
              aria-expanded="false"
              aria-haspopup="listbox"
              class="text-[11px] px-2 py-1 rounded border cursor-pointer flex items-center gap-1.5 border-border bg-surface-2 text-gray-400 hover:text-gray-200"
              type="button"
            >
              <span>
                Event type
              </span>
            </button>
          </div>
          <div
