          Why
        </button>
        <span
          class="text-[10.5px] text-gray-600 truncate"
        >
          Most TUI features carry over. A handful of interactive ones don't.
        </span>
      </div>
    </div>
    <div
      class="rounded-xl border border-border bg-surface-1"
    >
      <div
        class="border-b border-border px-4 py-3"
      >
        <div
          class="text-[11px] font-semibold uppercase tracking-wider text-gray-500 mb-2"
        >
          Mode
        </div>
        <div
          class="grid grid-cols-1 sm:grid-cols-2 gap-2"
        >
          <button
            class="text-left rounded-lg border px-3 py-2.5 transition-colors border-accent/40 bg-accent/10"
          >
            <div
              class="text-sm font-medium text-accent"
            >
              Conversation
            </div>
            <div
              class="text-[11px] text-gray-500 mt-0.5"
            >
              Multi-turn - keep typing follow-ups while the agent works.
            </div>
          </button>
          <button
            class="text-left rounded-lg border px-3 py-2.5 transition-colors border-border bg-surface-2 hover:bg-surface-3"
          >
            <div
              class="text-sm font-medium text-gray-200"
            >
              One-shot
            </div>
            <div
              class="text-[11px] text-gray-500 mt-0.5"
            >
              Single prompt, single response. Stdin closes after spawn.
            </div>
          </button>
        </div>
      </div>
      <div
        class="border-b border-border px-4 py-3"
      >
        <div
          class="text-[11px] font-semibold uppercase tracking-wider text-gray-500 mb-2"
        >
          Source session
        </div>
        <div
          class="grid grid-cols-1 sm:grid-cols-2 gap-2"
        >
          <button
            class="text-left rounded-lg border px-3 py-2.5 transition-colors border-accent/40 bg-accent/10"
          >
            <div
              class="text-sm font-medium text-accent"
            >
              New session
            </div>
            <div
              class="text-[11px] text-gray-500 mt-0.5"
            >
              Start a fresh Claude Code session.
            </div>
          </button>
          <button
            class="text-left rounded-lg border px-3 py-2.5 transition-colors border-border bg-surface-2 hover:bg-surface-3"
          >
            <div
              class="text-sm font-medium text-gray-200"
            >
              Resume existing session
            </div>
            <div
              class="text-[11px] text-gray-500 mt-0.5"
            >
              Pick a session from your history and continue the conversation. Cwd is locked to the original.
            </div>
          </button>
        </div>
      </div>
      <div
        class="px-4 py-3 border-b border-border"
      >
        <label
          class="block text-[11px] font-semibold uppercase tracking-wider text-gray-500 mb-1.5"
        >
          Prompt
        </label>
        <div
          class="relative"
        >
          <textarea
            class="w-full bg-surface-2 border border-border rounded-md px-3 py-2 text-sm text-gray-100 placeholder:text-gray-500 focus:outline-none focus:border-accent/50 resize-y font-sans leading-relaxed"
            placeholder="Ask Claude anything…"
            rows="5"
            spellcheck="false"
          />
        </div>
        <div
          class="mt-1 text-[10px] text-gray-600"
        >
          Cmd+Enter / Ctrl+Enter to send
           · / for slash commands · @ for file references
        </div>
      </div>
      <div
        class="grid grid-cols-1 md:grid-cols-3 gap-3 px-4 py-3"
      >
        <div>
          <label
            class="block text-[10px] font-semibold uppercase tracking-wider text-gray-500 mb-1"
          >
            Working directory
          </label>
          <div
            class="relative"
          >
            <div
              class="relative"
            >
              <svg
                class="lucide lucide-folder-open absolute left-2 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-gray-500 pointer-events-none"
                fill="none"
                height="24"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                viewBox="0 0 24 24"
                width="24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="m6 14 1.5-2.9A2 2 0 0 1 9.24 10H20a2 2 0 0 1 1.94 2.5l-1.54 6a2 2 0 0 1-1.95 1.5H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h3.9a2 2 0 0 1 1.69.9l.81 1.2a2 2 0 0 0 1.67.9H18a2 2 0 0 1 2 2v2"
                />
              </svg>
              <input
                autocomplete="off"
                class="w-full bg-surface-2 border border-border rounded-md pl-7 pr-3 py-1.5 text-[11px] font-mono text-gray-100 placeholder:text-gray-500 focus:outline-none focus:border-accent/50"
                placeholder="Type to search or paste an absolute path…"
                spellcheck="false"
                type="text"
                value=""
              />
            </div>
          </div>
          <p
            class="mt-1 text-[10px] text-gray-500"
          >
            Absolute path. Defaults to the dashboard's own cwd.
          </p>
        </div>
        <div>
          <label
            class="block text-[10px] font-semibold uppercase tracking-wider text-gray-500 mb-1"
          >
            Model
          </label>
          <div
            class="space-y-1.5"
          >
            <div
              class="relative"
            >
              <button
                class="w-full flex items-center justify-between gap-2 bg-surface-2 border border-border rounded-md px-3 py-1.5 text-[11px] text-gray-100 focus:outline-none focus:border-accent/50 hover:bg-surface-3 transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
                type="button"
              >
                <span
                  class="truncate"
                >
                  Inherit from settings
                </span>
                <svg
                  class="lucide lucide-chevron-down w-3.5 h-3.5 text-gray-500 flex-shrink-0"
                  fill="none"
                  height="24"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                  width="24"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="m6 9 6 6 6-6"
                  />
                </svg>
              </button>
            </div>
          </div>
        </div>
        <div>
          <label
            class="block text-[10px] font-semibold uppercase tracking-wider text-gray-500 mb-1"
          >
            Permission mode
          </label>
          <div
            class="relative"
          >
            <button
              class="w-full flex items-center justify-between gap-2 bg-surface-2 border border-border rounded-md px-3 py-1.5 text-[11px] text-gray-100 focus:outline-none focus:border-accent/50 hover:bg-surface-3 transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
              type="button"
            >
              <span
                class="truncate"
              >
                acceptEdits (recommended)
              </span>
              <svg
                class="lucide lucide-chevron-down w-3.5 h-3.5 text-gray-500 flex-shrink-0"
                fill="none"
                height="24"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                viewBox="0 0 24 24"
                width="24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="m6 9 6 6 6-6"
                />
              </svg>
            </button>
          </div>
        </div>
        <div>
          <label
            class="block text-[10px] font-semibold uppercase tracking-wider text-gray-500 mb-1"
          >
            Thinking effort
          </label>
          <div
            class="relative"
          >
            <button
              class="w-full flex items-center justify-between gap-2 bg-surface-2 border border-border rounded-md px-3 py-1.5 text-[11px] text-gray-100 focus:outline-none focus:border-accent/50 hover:bg-surface-3 transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
              type="button"
            >
              <span
                class="truncate"
              >
                Default (model decides)
              </span>
              <svg
                class="lucide lucide-chevron-down w-3.5 h-3.5 text-gray-500 flex-shrink-0"
                fill="none"
                height="24"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                viewBox="0 0 24 24"
                width="24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="m6 9 6 6 6-6"
                />
              </svg>
            </button>
          </div>
          <p
            class="mt-1 text-[10px] text-gray-500"
          >
            Drives how much the model reasons before answering. Higher = more thinking tokens, slower, deeper. Empty inherits the model's default.
          </p>
        </div>
      </div>
      <div
        class="border-t border-border px-4 py-3 flex items-center justify-between gap-3 flex-wrap"
      >
        <div
          class="flex items-center gap-3 text-[11px] min-w-0"
        />
        <button
          class="inline-flex items-center gap-2 rounded-lg border border-accent/40 bg-accent/15 hover:bg-accent/25 text-accent px-4 py-1.5 text-sm font-medium transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
          disabled=""
        >
          <svg
            class="lucide lucide-play w-3.5 h-3.5"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <polygon
              points="6 3 20 12 6 21 6 3"
            />
          </svg>
          Run
        </button>
      </div>
    </div>
  </div>
</div>
`;

