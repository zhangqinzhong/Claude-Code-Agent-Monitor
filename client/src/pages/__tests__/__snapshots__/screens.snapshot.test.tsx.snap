        </div>
        <div
          class="min-w-0 flex-1"
        >
          <div
            class="text-sm font-semibold text-gray-100 leading-tight"
          >
            Running Claude in your browser
          </div>
          <div
            class="mt-1 inline-flex items-center gap-2 text-[11px] text-gray-500"
          >
            <span
              class="font-mono px-1.5 py-0.5 rounded border border-border bg-surface-2/60 text-gray-400"
            >
              stream-json
            </span>
            <span
              class="text-gray-600"
            >
              ·
            </span>
            <span>
              same binary, different surface
            </span>
          </div>
        </div>
      </div>
      <div
        class="grid grid-cols-1 md:grid-cols-2 gap-2.5 mt-3.5 pl-12 pr-1"
      >
        <div
          class="rounded-lg border border-emerald-500/20 bg-emerald-500/[0.05] px-3.5 py-2.5"
        >
          <div
            class="text-[11px] font-semibold text-emerald-300 mb-1.5 inline-flex items-center gap-1.5 uppercase tracking-wide"
          >
            <svg
              class="lucide lucide-circle-check w-3.5 h-3.5"
              fill="none"
              height="24"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              viewBox="0 0 24 24"
              width="24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <circle
                cx="12"
                cy="12"
                r="10"
              />
              <path
                d="m9 12 2 2 4-4"
              />
            </svg>
            Works here
          </div>
          <ul
            class="text-[11.5px] text-gray-300 leading-[1.55] space-y-1 marker:text-emerald-500/40 list-disc pl-4"
          >
            <li>
              Live streaming output - text, thinking, tool calls, tool results
            </li>
            <li>
              Multi-turn conversations & resuming any past session
            </li>
            <li>
              User / project / plugin slash commands (template expansion)
            </li>
            <li>
              <code
                class="text-[10.5px] text-gray-200"
              >
                @
              </code>
              -references to files in the working directory
            </li>
            <li>
              Live token / context-window meter
            </li>
            <li>
              Active-runs switcher; full transcripts in
               
              <code
                class="text-[10.5px] text-gray-200"
              >
                /sessions
              </code>
            </li>
          </ul>
        </div>
        <div
          class="rounded-lg border border-rose-500/20 bg-rose-500/[0.05] px-3.5 py-2.5"
        >
          <div
            class="text-[11px] font-semibold text-rose-300 mb-1.5 inline-flex items-center gap-1.5 uppercase tracking-wide"
          >
            <svg
              class="lucide lucide-circle-x w-3.5 h-3.5"
              fill="none"
              height="24"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              viewBox="0 0 24 24"
              width="24"
