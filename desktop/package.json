{
  "name": "agent-dashboard-desktop",
  "version": "1.1.0",
  "private": true,
  "description": "Native macOS desktop shell for Claude Code Agent Monitor.",
  "main": "out/main.js",
  "scripts": {
    "clean": "rm -rf out release",
    "prebuild": "node scripts/prebuild.js",
    "build": "npm run prebuild && tsc -p tsconfig.json",
    "build:icons": "bash scripts/build-icons.sh",
    "dev": "npm run build && electron out/main.js",
    "package": "npm run build && electron-builder --mac --universal --publish never",
    "dmg": "npm run package",
    "test": "npm run build && node --test --test-reporter=spec tests/smoke.test.mjs",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "electron": "^35.7.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.5.4"
  }
}
